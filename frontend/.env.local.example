# NextAuth (v5 uses AUTH_SECRET; NEXTAUTH_* kept for compatibility)
AUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

NEXT_PUBLIC_API_URL=http://localhost:8000/v1
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENV=sandbox

# Sentry (error tracking) — leave empty to disable. Set in Vercel for prod.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=production
# Optional: enables source-map upload during build (set in Vercel)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
